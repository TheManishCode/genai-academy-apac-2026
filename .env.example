APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# NVIDIA NIM (base LLM provider for the decision assistant, get a free key at
# https://build.nvidia.com — model switching just changes NVIDIA_NIM_MODEL or
# the per-request "model" field to any id in NVIDIA_NIM_MODELS)
LLM_PROVIDER=nvidia_nim
NVIDIA_NIM_API_KEY=
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_NIM_MODEL=meta/llama-3.1-70b-instruct
NVIDIA_NIM_MODELS=meta/llama-3.1-70b-instruct,nvidia/llama-3.1-nemotron-70b-instruct,mistralai/mixtral-8x22b-instruct-v0.1,google/gemma-2-27b-it
NVIDIA_NIM_TEMPERATURE=0.4
NVIDIA_NIM_MAX_TOKENS=512

# Google Cloud (optional; only needed for real BigQuery/Vertex AI/GCS wiring)
GOOGLE_CLOUD_PROJECT=your-gcp-project
GOOGLE_CLOUD_LOCATION=us-central1
BIGQUERY_DATASET=ecomind
GCS_BUCKET=ecomind-ai-data
VERTEX_MODEL=gemini-2.5-pro
GEMINI_API_KEY=

# Firebase (optional; only needed for real auth)
FIREBASE_PROJECT_ID=your-firebase-project
FIREBASE_WEB_API_KEY=
FIREBASE_AUTH_DOMAIN=

# Frontend
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
